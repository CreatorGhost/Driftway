<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Bespoke Driftway menu action tile — replaces the generic Material tonal pill so the
         menu reads as a designed cinematic surface, not a default browser grid. -->
    <style name="Widget.Driftway.MenuAction" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">#232E44</item>
        <item name="iconTint">#4D9BFF</item>
        <item name="android:textColor">#E6ECF7</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">78dp</item>
        <item name="iconSize">26dp</item>
        <item name="iconPadding">6dp</item>
        <item name="rippleColor">#334D9BFF</item>
    </style>

    <!-- Soft, full-width action ROW for the redesigned menu (replaces the old button grid):
         left blue icon, left label, generous height, subtle ripple. -->
    <style name="Widget.Driftway.MenuRow" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:minHeight">58dp</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:textColor">#E6ECF7</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="iconTint">#EAF1FF</item>
        <item name="iconSize">26dp</item>
        <item name="iconPadding">20dp</item>
        <item name="iconGravity">textStart</item>
        <item name="android:paddingStart">22dp</item>
        <item name="android:paddingEnd">22dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="rippleColor">#334D9BFF</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

    <!-- Radio/option labels (Auto/Light/Dark, scale %, etc.) — force the on-surface color so
         they stay readable on the dark Driftway settings cards instead of a dim default. -->
    <style name="Widget.Driftway.Radio" parent="Widget.Material3.CompoundButton.RadioButton">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.BodyLarge</item>
    </style>

    <style name="Theme.AABrowser" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Driftway dark splash (Android 12+): replaces the jarring light launch screen. -->
        <item name="android:windowSplashScreenBackground">#04060C</item>
        <item name="radioButtonStyle">@style/Widget.Driftway.Radio</item>
        <item name="colorPrimary">@color/theme_primary</item>
        <item name="colorOnPrimary">@color/theme_on_primary</item>
        <item name="colorPrimaryContainer">@color/theme_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/theme_on_primary_container</item>
        <item name="colorSecondary">@color/theme_secondary</item>
        <item name="colorOnSecondary">@color/theme_on_secondary</item>
        <item name="colorSecondaryContainer">@color/theme_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/theme_on_secondary_container</item>
        <item name="colorTertiary">@color/theme_tertiary</item>
        <item name="colorOnTertiary">@color/theme_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/theme_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/theme_on_tertiary_container</item>
        <item name="colorError">@color/theme_error</item>
        <item name="colorOnError">@color/theme_on_error</item>
        <item name="colorErrorContainer">@color/theme_error_container</item>
        <item name="colorOnErrorContainer">@color/theme_on_error_container</item>
        <item name="android:colorBackground">@color/theme_background</item>
        <item name="colorOnBackground">@color/theme_on_background</item>
        <item name="colorSurface">@color/theme_surface</item>
        <item name="colorOnSurface">@color/theme_on_surface</item>
        <item name="colorSurfaceVariant">@color/theme_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/theme_on_surface_variant</item>
        <item name="colorOutline">@color/theme_outline</item>
        <item name="colorOutlineVariant">@color/theme_outline_variant</item>
        <item name="colorSurfaceContainerLowest">@color/theme_surface_container_lowest</item>
        <item name="colorSurfaceContainerLow">@color/theme_surface_container_low</item>
        <item name="colorSurfaceContainer">@color/theme_surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/theme_surface_container_high</item>
        <item name="colorSurfaceContainerHighest">@color/theme_surface_container_highest</item>
        <item name="android:windowBackground">@color/theme_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/theme_background</item>
        <!-- Driftway shape identity: a soft squircle scale applied to all Material components -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Driftway.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Driftway.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Driftway.Large</item>
        <!-- Bold, glanceable type roles for headlines/titles (car legibility) -->
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Driftway.HeadlineMedium</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Driftway.TitleLarge</item>
    </style>

    <!-- Bottom Sheet Shape -->
    <style name="ShapeAppearanceOverlay.App.Card.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">28dp</item>
        <item name="cornerSizeTopRight">28dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- ===== Driftway shape scale (soft squircle, generous corners) ===== -->
    <style name="ShapeAppearance.Driftway.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>
    <style name="ShapeAppearance.Driftway.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">22dp</item>
    </style>
    <style name="ShapeAppearance.Driftway.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">30dp</item>
    </style>

    <!-- ===== Driftway type scale (bold/emphasized for glanceable headlines) ===== -->
    <style name="TextAppearance.Driftway.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textFontWeight">800</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>
    <style name="TextAppearance.Driftway.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textFontWeight">700</item>
    </style>

</resources>
